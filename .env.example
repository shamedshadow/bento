DATABASE_URL=sqlite+aiosqlite:///./data/bento.db
PHOTOS_DIR=./data/photos
# Set BENTO_COOKIE_SECURE=true when serving over HTTPS (e.g., behind a reverse proxy).
BENTO_COOKIE_SECURE=false
# Optional: pin a session secret. If unset, one is generated and stored in the DB.
# BENTO_SESSION_SECRET=
# Optional: USDA FoodData Central API key. Without it, text search only hits the
# local cache. Free key: https://fdc.nal.usda.gov/api-key-signup.html
# USDA_API_KEY=
# Optional: allow visitors to create their own accounts at /auth/signup. Default
# false — accounts are created by an admin and shared via magic link.
# BENTO_OPEN_SIGNUP=false
